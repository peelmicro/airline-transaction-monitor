{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (per service)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count[1m])",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Error Rate (per service)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[1m])",
          "legendFormat": "{{job}} errors"
        }
      ]
    },
    {
      "title": "P95 Latency (per service)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{job}} P95"
        }
      ]
    },
    {
      "title": "NATS Consumer Lag",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "nats_consumer_num_pending",
          "legendFormat": "{{stream}} / {{consumer}}"
        }
      ]
    },
    {
      "title": "DB Connection Pool",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "db_client_connections_usage{state=\"used\"}",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["airline-monitor"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Airline Transaction Monitor",
  "uid": "airline-monitor"
}
